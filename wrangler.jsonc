{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mjp-droppfy",
  "compatibility_date": "2025-01-01",
  "pages_build_output_dir": ".",
  "vars": {
    "ALLOWED_ORIGIN": "https://mjp.droppfy.com"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mjp-apoiadores",
      "database_id": "COLE_O_ID_DO_D1_AQUI"
    }
  ]
}
